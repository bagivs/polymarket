# Polymarket HFT bot — environment template
# Copy to .env and fill in. NEVER commit .env (it's in .gitignore).
# NEVER share secret values in chat with AI assistants — see docs/DECISIONS.md.

# ---- GitHub (used by scripts/git-credential-env.sh for repo push) ----
github_PAT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ---- Polymarket CLOB (Sprint 03+: order placement) ----
# L1 — Ethereum private key, signs EIP-712 orders. ROTATE if ever leaked.
# Generate fresh; do not paste in chat.
PRIVATE_KEY=0x...

# L2 — CLOB API credentials (HMAC). Created via py-clob-client after L1 is set.
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Relay (off-chain order routing)
POLYMARKET_RELAY_API_KEY=
POLYMARKET_RELAY_API_ADDRESS=0x...

# ---- On-chain ----
# Polygon mainnet RPC. Public endpoint works; paid (Alchemy/Infura/QuickNode) for higher throughput.
POLYGON_RPC_URL=https://polygon-rpc.com

# EOA used to fund the Polymarket proxy wallet
FUNDER_ADDRESS=0x...
